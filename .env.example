# SvelteKit public
PUBLIC_BASE_URL=http://localhost:5175
PUBLIC_APP_TITLE=Lanzones Scan

# Turso (dev: local sqlite file)
TURSO_CONFIG=dev
TURSO_CONNECTION_URL=
TURSO_AUTH_TOKEN=

# better-auth
BETTER_AUTH_SECRET=change-me-32-bytes-minimum
ORIGIN=http://localhost:5175

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lanzones-scan

# FastAPI bridge (must match the FastAPI service's env)
LANZONESSCAN_API_URL=http://localhost:8000
LANZONESSCAN_JWT_SECRET=change-me-shared-with-fastapi
LANZONESSCAN_JWT_AUDIENCE=lanzones-scan
LANZONESSCAN_JWT_TTL_SECONDS=300
